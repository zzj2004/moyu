# moyu Configuration
# Copy to .env and fill in your keys

# Default provider (deepseek, kimi, openai)
MOYU_PROVIDER=deepseek

# Default API key (used for the default provider)
MOYU_API_KEY=sk-your-deepseek-key

# Provider-specific keys
MOYU_KIMI_API_KEY=sk-your-kimi-key
MOYU_OPENAI_API_KEY=sk-your-openai-key

# Model override
MOYU_MODEL=deepseek-chat

# Base URL (for custom endpoints)
# MOYU_BASE_URL=https://api.deepseek.com/v1

# Permission mode: confirm or trusted
MOYU_PERMISSION_MODE=confirm

# Max tokens
MOYU_MAX_TOKENS=16384
# Ollama (local) - no API key needed
# MOYU_PROVIDER=ollama
# MOYU_MODEL=llama3
# MOYU_BASE_URL=http://localhost:11434/v1
